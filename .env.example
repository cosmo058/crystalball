# ── AI Provider ──────────────────────────────────────────────────────────────
# Set one or both keys. If both are present, Claude is used by default.
# Override with AI_PROVIDER=gemini to force Gemini.

ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
# AI_PROVIDER=gemini

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite is used by default. The file lives in the db_data Docker volume.
# DATABASE_URL=sqlite+aiosqlite:///./data/crystalball.db

# ── Server ────────────────────────────────────────────────────────────────────
# Port the frontend is exposed on (default 80)
# PORT=80

# ── CORS (optional) ──────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the backend API.
# Only needed if you access the backend directly (not through nginx proxy).
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
